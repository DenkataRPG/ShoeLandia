@model ShoeLandia.ViewModels.Item.AllItemsQueryModel
@{
    ViewData["Title"] = "All";
}
<form method="get">
    <div class="row text-white mb-5">
        <div class="form-group col-md-2 justify-content-between">
            <div class="form-group">
                <label></label>
                <select class="form-control">
                    <option value="3">3</option>
                    <option value="6">6</option>
                    <option value="9">9</option>
                </select>
            </div>
        </div>


        <div class="form-group col-md-3">
            <div class="form-group">
                <label></label>
                <select class="form-select" aria-label=".form-select example">
                    <option selected>Sort</option>
                    <option value="0">Newest</option>
                    <option value="1">Oldest</option>
                    <option value="2">Price (ascending)</option>
                    <option value="3">Price (descending)</option>
                </select>
            </div>
        </div>

        <div class="form-group col-md-3">
            <label></label>
            <input class="form-control" placeholder="...">
        </div>

        <div class="col-md-4">
            <div class="form-group mt-3 p-2">
                <input type="submit" value="Search" class="btn btn-primary" />
            </div>
        </div>
    </div>
    <div class="container text-center">
        <div class="row row-cols-3 align-text-center">

            @foreach (var item in Model.Items)
            {
                <div class="col-4">
                    <div class="card mb-3" style="width: 18rem;">
                        <img src="@item.GetImages[0]" class="card-img-top" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                        </div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">@item.Category</li>
                            <li class="list-group-item">@item.Price</li>
                            <li class="list-group-item">@item.Colors.ToString()</li>
                        </ul>
                        <div class="card-body">
                            <a href="#" class="card-link">Add to cart</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="card-link">More information</a>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</form>
