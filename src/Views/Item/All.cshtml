@model ShoeLandia.ViewModels.Item.AllItemsQueryModel

@{
    ViewData["Title"] = "All Products";
}

<form method="get">
    <div class="row text-white mb-5">
        <div class="form-group col-md-2 justify-content-between">
            <div class="form-group">
                <label for="ItemsPerPage">Show</label>
                <select name="ItemsPerPage" id="ItemsPerPage" class="form-control">
                    <option value="3" selected="@(Model.ItemsPerPage == 3)">3</option>
                    <option value="6" selected="@(Model.ItemsPerPage == 6)">6</option>
                    <option value="9" selected="@(Model.ItemsPerPage == 9)">9</option>
                </select>
            </div>
        </div>
        <div class="form-group col-md-3">
            <div class="form-group">
                <label for="ItemsSorting">Sort by</label>
                <select name="ItemsSorting" id="ItemsSorting" class="form-select" aria-label="Sort options">
                    <option value="0" selected="@(Model.ItemsSorting == ShoeLandia.Views.Item.Enums.ItemsSorting.Name)">Name</option>
                    <option value="3" selected="@(Model.ItemsSorting == ShoeLandia.Views.Item.Enums.ItemsSorting.PriceAscending)">Price (ascending)</option>
                    <option value="4" selected="@(Model.ItemsSorting == ShoeLandia.Views.Item.Enums.ItemsSorting.PriceDescending)">Price (descending)</option>
                </select>
            </div>
        </div>
        <div class="form-group col-md-3">
            <label for="SearchString">Search</label>
            <input name="SearchString" id="SearchString" class="form-control" placeholder="Search..." value="@Model.SearchString">
        </div>
        <div class="col-md-4">
            <div class="form-group mt-3 p-2">
                <input type="submit" value="Search" class="btn btn-primary" />
            </div>
        </div>
    </div>
    <div class="container text-center">
        <div class="row row-cols-3 align-text-center">
            @foreach (var item in Model.Items)
            {
                <div class="col-4">
                    <div class="card mb-3" style="width: 18rem;">
                        <!-- Лента с намаление -->
                        <div class="discount-banner">20% OFF</div>
                        <img src="@item.GetImages[0]" class="card-img-top" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                        </div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">@item.Category</li>
                            <li class="list-group-item">@item.Price</li>
                            <li class="list-group-item">@item.Colors.ToString()</li>
                        </ul>
                        <div class="card-body">
                            <a href="#" class="card-link">Add to cart</a>
                            <a href="/Item/Details/@item.Id" class="card-link">More information</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</form>
<style>
    .discount-banner {
        position: absolute;
        top: 10px;
        left: 10px;
        background-color: red;
        color: white;
        padding: 5px 15px;
        font-weight: bold;
        font-size: 1.2rem;
        transform: rotate(-15deg);
    }

    .card {
        position: relative;
    }
</style>